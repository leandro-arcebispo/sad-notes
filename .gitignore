# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# banco local (SQLite) — dados de dev não versionados
/data/*.db
/data/*.db-wal
/data/*.db-shm

# sprites recortados pelo usuário (gerados em runtime; catálogo vive no banco)
# obs: mantemos a pasta versionada com .gitkeep, mas ignoramos os PNGs gerados
/public/sprites/**/*.png

# avatares compostos (PNG cacheado, gerado via sharp a partir da receita no banco)
/public/avatars/*.png

# spritesheets enviadas (fallback de storage local em dev; em prod vão pro Blob)
/public/sheets/

# arquivos-fonte do GIMP (working files de arte; não devem ser servidos em /public)
/public/gimp-projects/

# misc
.DS_Store
*.pem
.env*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
