# Copie este arquivo para `.env.local` e defina a senha ANTES de expor o app
# na internet (túnel Cloudflare). Sem BASIC_AUTH_PASSWORD, a trava fica
# desligada (ok em desenvolvimento local).

# Senha compartilhada com os amigos (obrigatória em produção):
BASIC_AUTH_PASSWORD=troque-esta-senha

# Usuário do prompt de login (opcional, default "amigos"):
# BASIC_AUTH_USER=amigos
